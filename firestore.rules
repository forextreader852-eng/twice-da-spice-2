rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // 3. PRIMITIVE DEFINITIONS
    // ==========================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'forextreader852@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // ==========================================
    // VALIDATION BLUEPRINTS
    // ==========================================

    function isValidMenuItem(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'isAvailable']) &&
             data.keys().size() <= 6 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.category in ['BBQ', 'Fast Food', 'Chinese', 'Desi', 'Drinks'] &&
             data.isAvailable is bool &&
             (data.get('description', '') is string && data.get('description', '').size() <= 500) &&
             (data.get('image', '') is string && data.get('image', '').size() <= 1000);
    }

    function isValidCartItem(item) {
      return item.keys().hasAll(['id', 'name', 'price', 'quantity', 'category', 'image']) &&
             item.id is string &&
             item.name is string &&
             item.price is number &&
             item.quantity is number && item.quantity > 0 && item.quantity <= 100;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerName', 'phone', 'address', 'items', 'totalAmount', 'status', 'createdAt', 'orderId']) &&
             data.keys().size() == 8 &&
             data.customerName is string && data.customerName.size() <= 100 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.address is string && data.address.size() <= 500 &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 50 &&
             // List validation check for first item
             isValidCartItem(data.items[0]) &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['pending', 'preparing', 'delivered', 'cancelled'] &&
             data.createdAt == request.time &&
             data.orderId is string && data.orderId.size() <= 50;
    }

    // ==========================================
    // 0. GLOBAL SAFETY NET
    // ==========================================
    
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // COLLECTION RULES
    // ==========================================

    match /menu/{menuId} {
      allow read: if true;
      
      allow create: if isAdmin() && isValidMenuItem(incoming()) && isValidId(menuId);
      
      allow update: if isAdmin() && isValidMenuItem(incoming()) && (
        // Full update by admin
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'price', 'category', 'image', 'isAvailable'])
      );
      
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      // Public can create orders
      allow create: if isValidOrder(incoming()) && isValidId(orderId);
      
      // Allow get for order tracking (anonymous)
      allow get: if true;
      
      // Only admin can list orders
      allow list: if isAdmin();
      
      allow update: if (
        isAdmin() && isValidOrder(incoming()) && (
          // Action: Update Status
          (incoming().diff(existing()).affectedKeys().hasOnly(['status']) && 
           existing().status != 'delivered' && existing().status != 'cancelled') ||
          // Action: Full Update (Admin only)
          (incoming().diff(existing()).affectedKeys().hasOnly(['customerName', 'phone', 'address', 'items', 'totalAmount', 'status', 'orderId', 'createdAt']))
        )
      );
      
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // System bootstrap only
    }
  }
}
